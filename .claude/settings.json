{
  "environmentVariables": {
    "VIBECODING_VERSION": "1.0.0",
    "LANGUAGE": "zh-Hans"
  },
  "permissions": {
    "allow": [
      "Bash(pnpm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(git *)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)"
    ],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{ "type": "command", "command": "node .claude/hooks/context-loader.cjs" }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "node .claude/hooks/pre-bash.cjs" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": "node .claude/hooks/post-edit.cjs" }]
      }
    ],
    "Stop": [
      {
        "hooks": [{ "type": "command", "command": "node .claude/hooks/delivery-gate.cjs" }]
      },
      {
        "hooks": [{ "type": "command", "command": "node .claude/hooks/tdd-check.cjs" }]
      }
    ],
    "StopFailure": [
      {
        "hooks": [{ "type": "command", "command": "node .claude/hooks/stop-failure.cjs" }]
      }
    ]
  }
}